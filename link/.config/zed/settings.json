// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "edit_predictions": {
    "provider": "zed",
  },
  "colorize_brackets": true,
  "context_servers": {
    "mcp-server-buildkite": {
      "enabled": true,
      "remote": false,
      "settings": {
        "buildkite_api_token": "BUILDKITE_API_TOKEN",
      },
    },
    "ember": {
      "enabled": true,
      "command": "npx",
      "args": ["-y", "ember-mcp"],
      "env": {},
    },
    "sentry": {
      "enabled": true,
      "command": "npx",
      "args": ["@sentry/mcp-server@latest", "--host=errors.teamtailor.com"],
      "env": {},
    },
    "browsermcp": {
      "enabled": true,
      "command": "npx",
      "args": ["@browsermcp/mcp@latest"],
    },
  },
  "icon_theme": "Catppuccin Frappé",
  "ssh_connections": [
    {
      "host": "192.168.1.158",
      "username": "jonas",
      "args": [],
      "projects": [
        {
          "paths": ["/Users/jonas"],
        },
        {
          "paths": ["/Users/jonas/code/posse_party"],
        },
        {
          "paths": ["/opt"],
        },
        {
          "paths": ["~/minecraft"],
        },
        {
          "paths": ["~/obsidian"],
        },
        {
          "paths": ["~/plexbox"],
        },
        {
          "paths": ["~/plexbox/arr"],
        },
      ],
    },
    {
      "host": "evil-ex-1",
      "username": "pi",
      "args": [],
      "projects": [
        {
          "paths": ["~/evil-exes"],
        },
      ],
    },
    {
      "host": "evil-ex-3",
      "username": "pi",
      "args": [],
      "projects": [
        {
          "paths": ["/mnt/nfs-ssd/zigbee2mqtt"],
        },
        {
          "paths": ["~/evil-exes"],
        },
      ],
    },
    {
      "host": "allthingsmini",
      "args": [],
      "projects": [],
    },
    {
      "host": "tacocat",
      "args": [],
      "projects": [
        {
          "paths": ["/opt"],
        },
      ],
    },
  ],
  "base_keymap": "Atom",
  "theme": "Catppuccin Latte",
  "buffer_font_family": "Operator Mono Lig",
  "buffer_font_size": 18,
  "buffer_line_height": "comfortable",
  "ui_font_family": "Operator Mono Lig",
  "ui_font_size": 17,
  "ui_font_weight": 200,

  "collaboration_panel": {
    "button": false,
  },

  "notification_panel": {
    "button": false,
  },

  "agent": {
    "favorite_models": [
      {
        "provider": "copilot_chat",
        "model": "gpt-5.2-codex",
      },
      {
        "provider": "copilot_chat",
        "model": "gemini-3-pro-preview",
      },
    ],
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.5",
    },

    "default_profile": "write",
    "always_allow_tool_actions": true,
    "default_model": {
      "provider": "copilot_chat",
      "model": "claude-opus-4.6",
    },
    "inline_alternatives": [
      {
        "provider": "copilot_chat",
        "model": "gpt-4o",
      },
    ],
    "enabled": true,
  },

  "tab_bar": {
    "show_nav_history_buttons": false,
  },

  "tabs": {
    "git_status": true,
  },

  "git_panel": {
    "sort_by_path": true,
  },

  "telemetry": {
    "metrics": false,
  },

  "terminal": {
    "dock": "bottom",
    "env": {
      "GIT_EDITOR": "zed --wait",
    },
    "option_as_meta": false,
    "detect_venv": {
      "on": {
        "directories": ["env", ".venv", "venv"],
      },
    },
  },

  "languages": {
    "Ruby": {
      "language_servers": [
        "ruby-lsp",
        "!standardrb",
        "!solargraph",
        "!rubocop",
      ],
      "formatter": "language_server",
    },
    "Handlebars": {
      "ensure_final_newline_on_save": false,
      "prettier": {
        "allowed": true,
      },
    },
    "Terraform": {
      "formatter": {
        "external": {
          "command": "tofu",
          "arguments": ["fmt", "-"],
        },
      },
    },
    "Terraform Vars": {
      "formatter": {
        "external": {
          "command": "tofu",
          "arguments": ["fmt", "-"],
        },
      },
    },
  },

  "lsp": {
    "ruby-lsp": {
      "initialization_options": {
        "enabledFeatures": {
          "diagnostics": true,
          "formatting": true,
        },
        "linters": ["standard"],
        "formatter": "standard",
      },
    },
    "tailwindcss-language-server": {
      "settings": {
        "includeLanguages": {
          "erb": "html",
          "ruby": "html",
        },
        "experimental": {
          "classRegex": ["\\bclass:\\s*['\"]([^'\"]*)['\"]"],
        },
      },
    },
  },
}
