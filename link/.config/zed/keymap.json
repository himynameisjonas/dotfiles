[
  {
    "context": "Editor",
    "bindings": {
      "cmd-shift-l": "editor::SplitSelectionIntoLines",
    },
  },
  {
    "bindings": { "cmd-/": "editor::ToggleComments" },
  },
  {
    "context": "Workspace",
    "bindings": {
      "cmd-}": "terminal_panel::ToggleFocus",
      "cmd-ctrl-a": "agent::ToggleFocus",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-r g": [
        "task::Spawn",
        {
          "task_name": "Lazygit",
        },
      ],

      "cmd-shift a": [
        "task::Spawn",
        {
          "task_name": "Alternate file",
          "reevaluate_context": true,
        },
      ],
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-r s": [
        "task::Spawn",
        {
          "task_name": "Start",
        },
      ],
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-r u": [
        "task::Spawn",
        {
          "task_name": "Update",
        },
      ],
    },
  },
  {
    "context": "Terminal",
    "bindings": {
      "shift-enter": ["terminal::SendText", "\u001b\r"],
    },
  },
]
